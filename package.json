{
  "name": "openclaw-manager",
  "version": "0.0.11",
  "description": "🦞 龙虾 OpenClaw Manager 小白版 - 面向非技术用户的 OpenClaw 本地可视化管理台",
  "author": "OpenClaw Team",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "version:patch": "node ./scripts/bump-version.mjs patch",
    "version:minor": "node ./scripts/bump-version.mjs minor",
    "version:major": "node ./scripts/bump-version.mjs major",
    "web-console": "node ./web-console/server.mjs",
    "web:api": "node ./web-console/server.mjs",
    "web:dev": "vite --mode web",
    "web:build": "vite build --mode web",
    "web:serve": "node ./web-console/server.mjs",
    "web:prod": "npm run web:build && npm run web:serve",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.2.0",
    "@tauri-apps/plugin-notification": "^2.2.0",
    "@tauri-apps/plugin-process": "^2.2.0",
    "@tauri-apps/plugin-shell": "^2.2.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
